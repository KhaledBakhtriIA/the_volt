################################################################################
# Volt Data API Configuration
# Copy this file to .env and fill in your actual values
################################################################################

# ============================================================================
# Core API Settings
# ============================================================================

# API Host and Port (0.0.0.0 for Docker, 127.0.0.1 for localhost)
DATA_API_HOST=0.0.0.0
DATA_API_PORT=8000

# Data collection interval (e.g., 1d, 1h, 15m)
DATA_API_INTERVAL=1d

# Historical lookback period in days for initial data collection
DATA_API_LOOKBACK_DAYS=365

# Storage preference
# Set to 'true' to use Parquet format; 'false' for CSV (default)
DATA_API_PREFER_PARQUET=false

# Data storage root directory
DATA_API_DATA_ROOT=data_api/data

# ============================================================================
# Data Retention and Archival
# ============================================================================

# Daily retention windows (days)
DATA_API_RETENTION_RAW_DAYS=14
DATA_API_RETENTION_PROCESSED_DAYS=30
DATA_API_RETENTION_EXPORTS_DAYS=60
DATA_API_RETENTION_ARCHIVE_DAYS=180

# Archive root path (optional). Defaults to <DATA_API_DATA_ROOT>/archive.
# DATA_API_ARCHIVE_ROOT=data_api/data/archive

# ============================================================================
# Browser Automation (Optional)
# ============================================================================

# Enable browser-based data collection (requires Playwright)
DATA_API_BROWSER_ENABLED=false

# Run browser in headless mode (no GUI)
DATA_API_BROWSER_HEADLESS=true

# Browser timeout in milliseconds
DATA_API_BROWSER_TIMEOUT_MS=30000

# Comma-separated browser targets (name=url pairs)
# Example: tradingview=https://...,investing=https://...
# DATA_API_BROWSER_TARGETS=

# ============================================================================
# Reddit Integration (Optional)
# ============================================================================

# Enable Reddit data collection
DATA_API_REDDIT_ENABLED=false

# Reddit API credentials (https://www.reddit.com/prefs/apps)
DATA_API_REDDIT_CLIENT_ID=
DATA_API_REDDIT_CLIENT_SECRET=
DATA_API_REDDIT_USER_AGENT=volt-data-api/1.0

# ============================================================================
# Macro Economic Data (Optional)
# ============================================================================

# Enable macro economic data from Federal Reserve
DATA_API_MACRO_ENABLED=false

# FRED API Key (https://fredaccount.stlouisfed.org/login)
DATA_API_FRED_API_KEY=

# Comma-separated FRED series IDs (key=id pairs)
# Example: fed_funds_rate=FEDFUNDS,cpi_all_items=CPIAUCSL
# DATA_API_FRED_SERIES=

# ============================================================================
# Desktop Capture (Optional, Linux/Windows only)
# ============================================================================

# Enable desktop screen capture
DATA_API_DESKTOP_ENABLED=false

# Interval between desktop captures in seconds
DATA_API_DESKTOP_CAPTURE_INTERVAL_SECONDS=5

# Comma-separated desktop targets (name=value pairs)
# Example: trading_terminal=active_screen
# DATA_API_DESKTOP_TARGETS=

# ============================================================================
# Advanced Features (Optional)
# ============================================================================

# Computer Vision (requires vision model dependencies)
DATA_API_VISION_ENABLED=false

# Stock Market Data
DATA_API_STOCK_MARKET_ENABLED=false

# Trading Strategy Analysis
DATA_API_TRADING_STRATEGY_ENABLED=false

# Trading Mistakes Analysis
DATA_API_TRADING_MISTAKES_ENABLED=false

# ============================================================================
# Third-Party APIs (Optional)
# ============================================================================

# TokenInsight (Crypto intelligence)
DATA_API_TOKENINSIGHT_ENABLED=false
DATA_API_TOKENINSIGHT_API_KEY=

# Financial Modeling Prep (FCS) - Market Data Fallback
# https://site.financialmodelingprep.com/
DATA_API_FCS_API_KEY=

# Finance Query Stream (Real-time market data)
DATA_API_FINANCE_QUERY_STREAM_ENABLED=false
DATA_API_FINANCE_QUERY_WS_URL=wss://stream.financequery.com/ws
DATA_API_FINANCE_QUERY_CHANNELS=ticker,trades,orderbook

# ============================================================================
# Logging and Debugging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Enable verbose logging
# VERBOSE=false

################################################################################
# Notes:
# - Fields with no value (empty string) are optional and disabled by default
# - Boolean values: true, false, yes, no, 1, 0
# - For Docker Compose: Use export VAR=VALUE before docker-compose up
# - Or create .env file in the same directory as docker-compose.yml
################################################################################
